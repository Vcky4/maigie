# Application Configuration
APP_NAME=Maigie API
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# API Configuration
API_V1_PREFIX=/api/v1

# CORS Configuration
# Use JSON array format for list fields
CORS_ORIGINS=["http://localhost:4200","http://localhost:5173","http://localhost:3000", "https://maigie.com", "https://dev.maigie.com","https://www.maigie.com", "https://app.maigie.com", "http://localhost:4201", "https://admin.maigie.com", "https://dev-admin.maigie.com"]
CORS_ALLOW_CREDENTIALS=true

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (for future use)
DATABASE_URL=postgresql://user:password@localhost:5432/maigie

# Redis (for future use)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# WebSocket
WEBSOCKET_HEARTBEAT_INTERVAL=30
WEBSOCKET_HEARTBEAT_TIMEOUT=60
WEBSOCKET_MAX_RECONNECT_ATTEMPTS=5

REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=maigie:
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# Auto-generated from REDIS_URL
CELERY_BROKER_URL=redis://localhost:6379/1      # Broker (DB 1)
CELERY_RESULT_BACKEND=redis://localhost:6379/2  # Results (DB 2)

# Task settings
CELERY_TASK_ALWAYS_EAGER=false  # Set true for testing (runs synchronously)
CELERY_TIMEZONE=UTC

SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.1

# OAuth Configuration
OAUTH_GOOGLE_CLIENT_ID="<Your Google Client ID>"
OAUTH_GOOGLE_CLIENT_SECRET="<Your Google Client Secret>"

#smtp Configuration
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAILS_FROM_EMAIL="hello@maigie.com"
EMAILS_FROM_NAME="Maigie"

# Resend fallback when primary SMTP fails (e.g. Brevo monthly quota). Optional RESEND_FROM_EMAIL must be verified in Resend.
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL="hello@maigie.com"
# When Brevo quota is exceeded, set resend_then_smtp or resend_only (SMTP cannot detect silent drops).
EMAIL_OUTBOUND_STRATEGY=smtp_then_resend

FRONTEND_BASE_URL="https://maigie.com" 

#bravo
BREVO_API_KEY=your-api-key-here
BREVO_ENABLED=true

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_WEBHOOK_DESTINATION_ID=""
# Maigie Plus (7-day trial)
STRIPE_PRICE_ID_MONTHLY=""
STRIPE_PRICE_ID_YEARLY=""
# Study Circle (3-day trial)
STRIPE_PRICE_ID_STUDY_CIRCLE_MONTHLY=""
STRIPE_PRICE_ID_STUDY_CIRCLE_YEARLY=""
# Squad Plan (3-day trial)
STRIPE_PRICE_ID_SQUAD_MONTHLY=""
STRIPE_PRICE_ID_SQUAD_YEARLY=""
FRONTEND_URL=http://localhost:4200

# Paystack (Nigeria - NGN). Webhook signature uses PAYSTACK_SECRET_KEY.
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
# Create plans in Paystack Dashboard, copy plan codes (e.g. PLN_xxx)
PAYSTACK_PLAN_MAIGIE_PLUS_MONTHLY=
PAYSTACK_PLAN_MAIGIE_PLUS_YEARLY=
PAYSTACK_PLAN_STUDY_CIRCLE_MONTHLY=
PAYSTACK_PLAN_STUDY_CIRCLE_YEARLY=
PAYSTACK_PLAN_SQUAD_MONTHLY=
PAYSTACK_PLAN_SQUAD_YEARLY=

EMAIL_LOGO_URL="https://maigie.com/assets/logo.png"

#bunny cdn
BUNNY_CDN_API_KEY= None
BUNNY_STORAGE_ZONE= None
BUNNY_CDN_HOSTNAME="cdn.maigie.com"
# Optional: public base with valid TLS if custom CDN hostname cert is broken, e.g. https://yourzone.b-cdn.net
BUNNY_PUBLIC_URL_BASE="https://maigie.b-cdn.net"

GEMINI_API_KEY="yijk"
# One comma-separated list for Gemini exam prep, schedule AI, etc. (round-robin on retry). Optional overrides: GEMINI_EXAM_PREP_MODELS, GEMINI_SCHEDULE_AI_MODELS.
GEMINI_ROTATING_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-2.0-flash-lite

# --- Multi-Provider LLM Configuration ---
# Provider API keys (leave empty to disable a provider)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Default models per provider
OPENAI_DEFAULT_MODEL=gpt-4o-mini
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514

# Circuit Breaker — trips after N failures within the rolling window, then cools down
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_SECONDS=30.0
CIRCUIT_BREAKER_ROLLING_WINDOW_SECONDS=60.0

# Retry — max attempts and exponential backoff base delay
LLM_MAX_RETRIES=2
LLM_RETRY_BASE_DELAY_SECONDS=1.0

# Fallback chains — comma-separated provider:model pairs tried in order on failure
FALLBACK_CHAT_DEFAULT=gemini:gemini-2.5-flash,openai:gpt-4o-mini,anthropic:claude-sonnet-4-20250514
FALLBACK_CHAT_TOOLS=gemini:gemini-2.5-flash,openai:gpt-4o,anthropic:claude-sonnet-4-20250514

# Feature flags — which providers are enabled (comma-separated). Default "gemini" for safe rollout.
LLM_ENABLED_PROVIDERS=gemini

# Tier-based model allowlists — comma-separated provider:model pairs each tier can access
LLM_TIER_ALLOWLIST_FREE=gemini:gemini-2.5-flash,gemini:gemini-2.0-flash-lite
LLM_TIER_ALLOWLIST_PLUS=gemini:gemini-2.5-flash,gemini:gemini-2.0-flash-lite,openai:gpt-4o-mini
LLM_TIER_ALLOWLIST_CIRCLE=gemini:gemini-2.5-flash,openai:gpt-4o,anthropic:claude-sonnet-4-20250514
LLM_TIER_ALLOWLIST_SQUAD=gemini:gemini-2.5-flash,openai:gpt-4o,anthropic:claude-sonnet-4-20250514

# Gemini Live (voice) — optional; defaults match Settings in config.py
# GEMINI_LIVE_MODEL=
# GEMINI_LIVE_GREETING_PROMPT=
# GEMINI_LIVE_CREDITS_PER_MINUTE=100
# GEMINI_LIVE_MIN_SESSION_CREDITS=500

# Celery schedule-AI batch cap (users processed per daily run)
# AI_SCHEDULE_REVIEW_MAX_USERS=500

# ElevenLabs (Smart AI Tutor, Exam Prep voice, Conversational AI agent)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_AGENT_ID=

# Pinecone (Vector Database for RAG — hosted on GCP)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=maigie
PINECONE_CLOUD=gcp
PINECONE_REGION=us-central1