// apps/backend/prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

// ==========================================
//  ENUMS
// ==========================================

enum Tier {
  FREE
  PREMIUM_MONTHLY // Maigie Plus
  PREMIUM_YEARLY // Maigie Plus
  STUDY_CIRCLE_MONTHLY
  STUDY_CIRCLE_YEARLY
  SQUAD_MONTHLY
  SQUAD_YEARLY
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ActionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum UserRole {
  USER
  ADMIN
}

/// Sub-role for users with UserRole.ADMIN (portal permissions).
enum AdminStaffRole {
  SUPER_ADMIN
  CONTENT_MANAGER
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
  CANCELLED
}

enum ScheduleBehaviourType {
  COMPLETED_ON_TIME
  COMPLETED_LATE
  SKIPPED
  RESCHEDULED
  AI_CREATED
}

enum ResourceType {
  VIDEO
  ARTICLE
  BOOK
  COURSE
  DOCUMENT
  WEBSITE
  PODCAST
  OTHER
}

enum InteractionType {
  RESOURCE_CLICK
  RESOURCE_VIEW
  RESOURCE_BOOKMARK
  RESOURCE_FEEDBACK
  COURSE_VIEW
  NOTE_CREATE
  NOTE_UPDATE
  GOAL_CREATE
  GOAL_UPDATE
  SCHEDULE_CREATE
  SCHEDULE_UPDATE
  CHAT_MESSAGE
  RECOMMENDATION_REQUESTED
  RECOMMENDATION_ACCEPTED
  RECOMMENDATION_REJECTED
}

enum ResourceBankType {
  TEXTBOOK
  NOTE
  ASSIGNMENT
  PAST_QUESTION
  SLIDES
  SUMMARY
  LAB_REPORT
  OTHER
}

enum ResourceBankStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  FLAGGED
}

enum ReportStatus {
  REPORT_PENDING
  REPORT_REVIEWED
  REPORT_DISMISSED
}

enum CircleRole {
  OWNER
  ADMIN
  TUTOR
  MEMBER
}

enum CircleInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum CircleSessionStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

/// Admin-recorded income vs operating expense (internal ledger).
enum LedgerLineKind {
  INCOME
  EXPENSE
}

// ==========================================
//  USER & AUTH
// ==========================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String? // Nullable for OAuth users
  name         String?
  provider     String? // "google", "email"
  providerId   String?
  tier         Tier     @default(FREE)
  role           UserRole        @default(USER)
  /// Set when role is ADMIN; null for normal users.
  adminStaffRole AdminStaffRole?
  isActive     Boolean  @default(true)
  isOnboarded  Boolean  @default(false)

  verificationCode          String? // Stores the 6-digit OTP
  verificationCodeExpiresAt DateTime? // Stores when it expires
  passwordResetCode         String?
  passwordResetExpiresAt    DateTime?

  // Stripe subscription fields
  stripeCustomerId               String?   @unique
  stripeSubscriptionId           String?   @unique
  stripeSubscriptionStatus       String?
  stripePriceId                  String?
  subscriptionCurrentPeriodStart DateTime?
  subscriptionCurrentPeriodEnd   DateTime?

  // Paystack subscription fields (Nigeria)
  paystackCustomerCode     String? @unique
  paystackSubscriptionCode String? @unique
  paymentProvider          String? // "stripe" | "paystack"

  // Credit tracking for subscription limits
  creditsUsed        Int       @default(0) // Credits consumed in current period
  creditsPeriodStart DateTime? // When current credit period started
  creditsPeriodEnd   DateTime? // When current credit period ends
  creditsSoftCap     Int? // Soft cap (warning threshold) - null means no soft cap
  creditsHardCap     Int? // Hard cap (blocking threshold) - null means no hard cap

  // Daily credit tracking (for FREE tier)
  creditsUsedToday  Int       @default(0) // Credits consumed today
  creditsDailyLimit Int? // Daily limit (only for FREE tier)
  lastDailyReset    DateTime? // When daily credits were last reset

  // Feature usage tracking (for FREE tier limits)
  fileUploadsCount              Int       @default(0) // Files uploaded in current period
  fileUploadsPeriodStart        DateTime? // When current file upload period started
  summaryGenerationsCount       Int       @default(0) // AI summaries generated in current period
  summaryGenerationsPeriodStart DateTime? // When current summary generation period started

  // Google Calendar integration
  googleCalendarAccessToken    String? // Encrypted access token for Google Calendar API
  googleCalendarRefreshToken   String? // Encrypted refresh token for Google Calendar API
  googleCalendarTokenExpiresAt DateTime? // When the access token expires
  googleCalendarSyncEnabled    Boolean   @default(false) // Whether Calendar sync is enabled
  googleCalendarId             String? // Primary calendar ID (usually "primary")

  // Referral tracking
  referredByCode String? // Referral code of the user who referred this user (immutable once set)

  // Limit reached email tracking (one email per period)
  limitReachedEmailLogs LimitReachedEmailLog[]

  // Relations
  preferences             UserPreferences?
  courses                 Course[]
  notes                   Note[]
  editedNotes             Note[] @relation("NoteLastEditedBy")
  noteHistories           NoteHistory[]
  resources               Resource[]
  goals                   Goal[]
  schedules               ScheduleBlock[]
  reviewItems             ReviewItem[]
  scheduleBehaviourLogs   ScheduleBehaviourLog[]
  userInteractionMemories UserInteractionMemory[]
  userFacts               UserFact[]

  // NEW: Chat Relations
  chatSessions ChatSession[]
  chatMessages ChatMessage[] // Direct relation to help count usage (e.g., "50 messages/month")

  // Analytics Relations
  studySessions StudySession[]
  userStreak    UserStreak?
  achievements  Achievement[]

  // Feedback Relations
  feedback Feedback[]

  // Referral Relations
  referralCode        String?               @unique // User's unique referral code
  referralRewards     ReferralReward[] // Rewards earned as referrer
  referralRewardClaim ReferralRewardClaim[] // Claims made by this user
  referredByRewards   ReferralReward[]      @relation("ReferredUser") // Rewards where this user was referred

  // Audit Relations
  auditLogs AuditLog[] @relation("AdminAuditLogs") // Audit logs created by this admin

  // Admin finance ledger (who created the line)
  ledgerLines LedgerLine[]

  // Exam Prep (Maigie Plus)
  examPreps       ExamPrep[]
  examQuizSessions ExamQuizSession[]

  // Resource Bank
  resourceBankItems          ResourceBankItem[]
  resourceBankReports        ResourceBankReport[]
  resourceUploadRewards      ResourceUploadReward[]
  resourceUploadRewardClaims ResourceUploadRewardClaim[]

  // Circle Relations
  circleMembers CircleMember[]
  circleStats   CircleMemberStat[]
  circleSessions CircleSession[]

  // Agentic AI Relations
  conversationSummaries ConversationSummary[]
  aiAgentTasks          AIAgentTask[]
  learningInsights      LearningInsight[]

  // OAuth 2.1 Provider Relations (ChatGPT Integration)
  oauthClients OAuthClient[] // Clients created by this user (optional)
  oauthCodes   OAuthCode[] // Auth codes issued to this user
  oauthTokens  OAuthToken[] // Access tokens issued to this user

  // Knowledge Base (user uploads indexed for RAG context)
  userUploads UserUpload[]

  // Gamification
  // points Int @default(0) // Note: using dynamic calculation for now

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
//  OAUTH 2.1 PROVIDER MODELS
// ==========================================

model OAuthClient {
  id           String  @id @default(uuid())
  clientId     String  @unique
  clientSecret String? // Optional for public clients (like ChatGPT Apps)

  clientName   String
  redirectUris String[] // Array of allowed redirect URIs
  clientUri    String?
  logoUri      String?

  // Dynamic Client Registration fields
  tokenEndpointAuthMethod String   @default("none") // "none" for public, "client_secret_post", "client_secret_basic"
  grantTypes              String[] @default(["authorization_code", "refresh_token"])
  responseTypes           String[] @default(["code"])

  // Who registered this client
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Tokens & Codes issued to this client
  codes  OAuthCode[]
  tokens OAuthToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model OAuthCode {
  id String @id @default(uuid())

  code     String      @unique
  clientId String
  client   OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  redirectUri String
  scope       String?

  // PKCE fields
  codeChallenge       String?
  codeChallengeMethod String? // e.g. "S256"

  expiresAt DateTime

  // Safety: ensure code is only used once
  isUsed Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([code])
  @@index([clientId])
  @@index([userId])
}

model OAuthToken {
  id String @id @default(uuid())

  accessToken  String  @unique
  refreshToken String? @unique

  clientId String
  client   OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  scope String?

  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime?

  // Optional linkage to an auth code if one produced it
  createdAt DateTime @default(now())

  @@index([accessToken])
  @@index([refreshToken])
  @@index([clientId])
  @@index([userId])
}

model UserPreferences {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme         String  @default("light")
  language      String  @default("en")
  notifications Boolean @default(true)
  studyGoals    Json?

  // Email notification preferences
  timezone              String  @default("UTC") // IANA timezone e.g. "America/New_York"
  emailMorningSchedule  Boolean @default(true)
  emailScheduleReminder Boolean @default(true)
  emailWeeklyTips       Boolean @default(true)
}

/// Tracks when we sent "limit reached" email to avoid spamming (one per credit period).
model LimitReachedEmailLog {
  id        String   @id @default(cuid())
  userId    String
  periodEnd DateTime
  sentAt    DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodEnd])
  @@index([userId])
}

// ==========================================
//  COURSES MODULE
// ==========================================

model Course {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String
  description   String?
  difficulty    Difficulty @default(BEGINNER)
  targetDate    DateTime?
  isAIGenerated Boolean    @default(false)
  archived      Boolean    @default(false)

  // Cached progress (0.0 to 100.0) — per-user even in circles
  progress Float @default(0.0)

  // Circle: if set, this course is shared within a circle (progress tracked per-user)
  circleId String?
  circle   Circle? @relation(fields: [circleId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  modules       Module[]
  notes         Note[]
  resources     Resource[] // Resources linked to this course
  goals         Goal[] // Goals linked to this course
  schedules     ScheduleBlock[] // Schedule blocks linked to this course
  studySessions StudySession[] // Study sessions for this course
  chatSessions  ChatSession[]

  @@index([userId])
  @@index([userId, archived])
  @@index([circleId])
}

model Module {
  id       String @id @default(cuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  title       String
  description String?
  order       Float   @default(0)
  completed   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topics Topic[]

  @@index([courseId])
  @@index([courseId, order])
}

model Topic {
  id       String @id @default(cuid())
  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  title          String
  content        String? // Markdown content
  order          Float   @default(0)
  completed      Boolean @default(false)
  estimatedHours Float?

  notes         Note[]
  resources     Resource[] // Resources linked to this topic
  goals         Goal[] // Goals linked to this topic
  schedules     ScheduleBlock[] // Schedule blocks linked to this topic
  studySessions StudySession[] // Study sessions for this topic
  reviewItems   ReviewItem[] // Spaced repetition: one review schedule per completed topic
  groupSessions CircleSession[] // Group sessions linked to this topic

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatSessions ChatSession[]

  @@index([moduleId])
  @@index([moduleId, order])
}

// ==========================================
//  CHAT & AI MODULE (NEW)
// ==========================================

model ChatSession {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title    String? // Auto-generated summary (e.g. "Biology Study Plan")
  isActive Boolean @default(true) // False if archived/deleted
  isCircleRoom Boolean @default(false)

  // Resource linkage (New: for per-page history persistence)
  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  examPrepId String?
  examPrep   ExamPrep? @relation(fields: [examPrepId], references: [id], onDelete: SetNull)

  noteId String?
  note   Note?   @relation(fields: [noteId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  // Conversation summaries for long-term memory
  conversationSummaries ConversationSummary[]

  // Circle chat group back-relation (if this session belongs to a circle group)
  circleChatGroup CircleChatGroup?

  @@index([userId])
  @@index([courseId])
  @@index([topicId])
  @@index([examPrepId])
  @@index([noteId])
  @@index([updatedAt]) // Useful for sorting "Recent Chats"
  @@index([isCircleRoom])
}

model ChatMessage {
  id String @id @default(cuid())

  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Spaced repetition / review threading (optional)
  reviewItemId String?
  reviewItem   ReviewItem? @relation("ReviewItemChatMessages", fields: [reviewItemId], references: [id], onDelete: SetNull)

  // Optional in-room reply/thread linkage
  replyToMessageId String?
  replyToMessage   ChatMessage?  @relation("ChatMessageReplies", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies          ChatMessage[] @relation("ChatMessageReplies")

  role    ChatRole // USER, ASSISTANT, SYSTEM
  content String // The Markdown text response

  // Suggestion text (e.g. "Would you like me to...") - displayed after components
  suggestionText String?

  // Voice features
  audioUrl  String? // S3 URL if this was a voice message
  imageUrl  String? // Legacy: single image URL (backward compat)
  imageUrls String[] // Multiple image URLs per message
  duration  Float? // Duration in seconds

  componentData Json? @default("[]") // Stores component metadata for interactive UI elements

  // Usage tracking (Critical for Free Tier limits)
  tokenCount Int @default(0)

  // Cost tracking
  inputTokens  Int? // Input tokens used (for ASSISTANT messages)
  outputTokens Int? // Output tokens used (for ASSISTANT messages)
  modelName    String? // Model used (e.g., "gemini-1.5-pro", "gpt-4")
  costUsd      Float?  @default(0) // Actual cost paid to AI provider (in USD)
  revenueUsd   Float?  @default(0) // Revenue charged to user (in USD)

  createdAt DateTime @default(now())

  // Relations
  actions AIActionLog[]

  @@index([sessionId])
  @@index([reviewItemId])
  @@index([sessionId, reviewItemId])
  @@index([userId]) // Helps count "messages this month" quickly
  @@index([createdAt]) // For cost/revenue analytics
  @@index([replyToMessageId])
}

model AIActionLog {
  id String @id @default(cuid())

  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  actionType String // e.g., "create_course", "create_goal"
  actionData Json // The actual JSON payload used
  status     ActionStatus @default(PENDING)
  error      String? // If status == FAILED

  createdAt DateTime @default(now())

  @@index([messageId])
}

// ==========================================
//  NOTES MODULE
// ==========================================

model Note {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  content String? // Rich text content
  summary String? // AI generated summary

  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  topicId String?
  topic   Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  // Circle: if set, this note is shared within a circle
  circleId String?
  circle   Circle? @relation(fields: [circleId], references: [id], onDelete: SetNull)

  // Tracking ownership and changes
  lastEditedById String?
  lastEditedBy   User? @relation("NoteLastEditedBy", fields: [lastEditedById], references: [id], onDelete: SetNull)

  archived          Boolean @default(false)
  voiceRecordingUrl String?

  tags        NoteTag[]
  attachments NoteAttachment[]
  history     NoteHistory[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatSessions ChatSession[]

  @@index([userId])
  @@index([courseId])
  @@index([topicId])
  @@index([userId, archived])
  @@index([circleId])
}

model NoteTag {
  id     String @id @default(cuid())
  noteId String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    String

  @@index([noteId])
  @@index([tag])
}

model NoteHistory {
  id        String   @id @default(cuid())
  noteId    String
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String?  // Rich text content at this version
  createdAt DateTime @default(now())

  @@index([noteId])
  @@index([userId])
}

model NoteAttachment {
  id       String @id @default(cuid())
  noteId   String
  note     Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  filename String
  url      String
  size     Int?

  createdAt DateTime @default(now())

  @@index([noteId])
}

// ==========================================
//  RESOURCES MODULE
// ==========================================

model Resource {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  url         String
  description String?
  type        ResourceType @default(OTHER)
  metadata    Json? // Additional metadata (author, duration, etc.)

  // Recommendation fields
  isRecommended        Boolean @default(false)
  recommendationScore  Float? // Score from 0.0 to 1.0
  recommendationSource String? // "ai", "manual", "similarity"
  recommendationReason String? // Why this resource was recommended (e.g., "for topic X", "related to course Y")

  // Optional links to courses/topics (why this resource is relevant)
  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  topicId  String?
  topic    Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  // Circle sharing
  circleId String?
  circle   Circle? @relation(fields: [circleId], references: [id], onDelete: SetNull)

  // User interaction tracking
  clickCount     Int       @default(0)
  bookmarkCount  Int       @default(0)
  lastAccessedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  embeddings Embedding[]

  @@index([userId])
  @@index([userId, isRecommended])
  @@index([type])
  @@index([courseId])
  @@index([topicId])
  @@index([circleId])
}

// ==========================================
//  GOALS MODULE
// ==========================================

model Goal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  description String?
  targetDate  DateTime?
  status      GoalStatus @default(ACTIVE)
  progress    Float      @default(0.0) // Progress from 0.0 to 100.0

  // Optional links to courses/topics (for context-aware goals)
  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  topicId  String?
  topic    Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  // Circle: if set, this goal is shared within a circle
  circleId String?
  circle   Circle? @relation(fields: [circleId], references: [id], onDelete: SetNull)

  schedules     ScheduleBlock[] // Schedule blocks linked to this goal
  groupSessions CircleSession[] // Group sessions linked to this goal

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([targetDate])
  @@index([courseId])
  @@index([topicId])
  @@index([circleId])
}

// ==========================================
//  SCHEDULE MODULE
// ==========================================

model ScheduleBlock {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title         String
  description   String?
  startAt       DateTime
  endAt         DateTime
  recurringRule String? // e.g., "RRULE:FREQ=WEEKLY;BYDAY=MO,WE,FR" or "DAILY", "WEEKLY", etc.

  // Google Calendar sync
  googleCalendarEventId  String? // ID of the event in Google Calendar
  googleCalendarSyncedAt DateTime? // When this was last synced to Google Calendar

  // Optional links to courses/topics/goals
  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  topicId  String?
  topic    Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)
  goalId   String?
  goal     Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)

  // Spaced repetition: when this block was created for a review
  reviewItemId String?     @unique
  reviewItem   ReviewItem? @relation(fields: [reviewItemId], references: [id], onDelete: SetNull)

  // Exam prep: study blocks scheduled before exam
  examPrepId String?
  examPrep   ExamPrep? @relation(fields: [examPrepId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, startAt])
  @@index([startAt, endAt])
  @@index([courseId])
  @@index([topicId])
  @@index([goalId])
  @@index([examPrepId])
}

// ==========================================
//  SPACED REPETITION & SCHEDULE BEHAVIOUR
// ==========================================

model ReviewItem {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  // Next review due (spaced repetition — SM-2 adaptive algorithm)
  nextReviewAt    DateTime
  intervalDays    Int       @default(1) // Current interval in days
  repetitionCount Int       @default(0) // Number of successful reviews (resets on lapse)
  easeFactor      Float     @default(2.5) // SM-2 ease factor (minimum 1.3)
  lastQuality     Int       @default(-1) // Last review quality 0-5 (-1 = never reviewed)
  lapseCount      Int       @default(0) // Total times the user lapsed (forgot / quality < 3)
  lastReviewedAt  DateTime?

  // The schedule block we created for the upcoming review (optional; back-relation from ScheduleBlock.reviewItemId)
  scheduleBlock ScheduleBlock?

  // Chat messages that happened during this review (optional)
  chatMessages ChatMessage[] @relation("ReviewItemChatMessages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, nextReviewAt])
  @@index([topicId])
}

model ScheduleBehaviourLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  behaviourType ScheduleBehaviourType
  entityType    String // "review", "schedule_block"
  entityId      String?

  scheduledAt DateTime? // When it was supposed to happen
  actualAt    DateTime? // When it actually happened (or null if skipped)
  metadata    Json? // Extra context for AI (e.g. reschedule reason, course title)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([behaviourType])
}

model Embedding {
  id String @id @default(cuid())

  // Object reference (polymorphic)
  objectType String // "resource", "note", "course", "topic"
  objectId   String // ID of the resource/note/course/topic

  // Vector embedding (stored as JSON array, will be converted to pgvector)
  // Using String for now - will need pgvector extension for proper vector type
  vector Json // Array of floats representing the embedding vector

  // Content that was embedded (for debugging/re-indexing)
  content  String? // The text content that was embedded
  metadata Json? // Additional metadata about the embedding

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  resourceId String?
  resource   Resource? @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  resourceBankItemId String?
  resourceBankItem   ResourceBankItem? @relation(fields: [resourceBankItemId], references: [id], onDelete: Cascade)

  @@index([objectType, objectId])
  @@index([resourceId])
  @@index([resourceBankItemId])
}

// ==========================================
//  EXAM PREP MODULE (Maigie Plus)
// ==========================================

enum ExamPrepStatus {
  SETUP // User is still uploading materials
  PROCESSING // AI is analyzing materials
  ACTIVE // Study plan generated, ready to study
  COMPLETED // Exam date passed or user marked complete
  ARCHIVED
}

enum MaterialCategory {
  TEXTBOOK
  NOTES
  PAST_QUESTION // Past exam papers
  LINK // Web links / articles
  SLIDE // Lecture slides
  OTHER
}

enum QuestionSource {
  PAST_QUESTION // Extracted from uploaded past papers
  AI_GENERATED // Generated by AI from study materials
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  FILL_IN_BLANK
}

enum QuestionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum QuizMode {
  FULL_PRACTICE // Random mix of all questions
  WEAK_AREAS // Only previously wrong questions
  TOPIC_FOCUS // Questions from a specific topic
  PAST_PAPER_SIM // Simulated past paper experience
  QUICK_REVIEW // 5-10 quick questions
}

model ExamPrep {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  subject     String
  examDate    DateTime
  description String?
  status      ExamPrepStatus @default(SETUP)

  // Circle sharing
  circleId String?
  circle   Circle? @relation(fields: [circleId], references: [id], onDelete: SetNull)

  // Relations
  materials    ExamPrepMaterial[]
  schedules    ScheduleBlock[]
  topics       ExamPrepTopic[]
  quizSessions ExamQuizSession[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  chatSessions ChatSession[]

  @@index([userId])
  @@index([userId, examDate])
  @@index([userId, status])
  @@index([examDate])
  @@index([circleId])
}

model ExamPrepMaterial {
  id         String   @id @default(cuid())
  examPrepId String
  examPrep   ExamPrep @relation(fields: [examPrepId], references: [id], onDelete: Cascade)

  filename      String
  url           String
  extractedText String? // AI-extracted text content for RAG/quiz
  fileType      String? // e.g., pdf, docx
  size          Int?
  category      MaterialCategory @default(OTHER)
  label         String? // User-defined label e.g. "2024 Midterm", "Chapter 5"

  // Relations
  questions ExamQuestion[] // Questions extracted from this material

  createdAt DateTime @default(now())

  @@index([examPrepId])
  @@index([examPrepId, category])
}

model ExamPrepTopic {
  id         String   @id @default(cuid())
  examPrepId String
  examPrep   ExamPrep @relation(fields: [examPrepId], references: [id], onDelete: Cascade)

  title       String
  description String?
  order       Int     @default(0)

  questions ExamQuestion[]

  createdAt DateTime @default(now())

  @@index([examPrepId])
}

model ExamQuestion {
  id      String        @id @default(cuid())
  topicId String
  topic   ExamPrepTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)

  source        QuestionSource
  questionText  String
  questionType  QuestionType   @default(MULTIPLE_CHOICE)
  options       Json? // Array of {label, text, isCorrect} for MCQ
  correctAnswer String? // For short answer / fill-in
  explanation   String // AI-generated explanation

  // From past questions
  materialId String? // Link back to the source material (if from past question)
  material   ExamPrepMaterial? @relation(fields: [materialId], references: [id], onDelete: SetNull)
  year       String? // e.g. "2023" if from a past paper

  // Difficulty & metadata
  difficulty QuestionDifficulty @default(MEDIUM)
  tags       String[]           @default([])

  attempts ExamQuestionAttempt[]

  createdAt DateTime @default(now())

  @@index([topicId])
  @@index([topicId, source])
  @@index([materialId])
}

model ExamQuizSession {
  id         String   @id @default(cuid())
  examPrepId String
  examPrep   ExamPrep @relation(fields: [examPrepId], references: [id], onDelete: Cascade)

  mode            QuizMode
  totalQuestions  Int
  correctCount    Int       @default(0)
  score           Float? // Percentage
  completedAt     DateTime?
  durationSeconds Int? // Time taken
  topicId         String? // If mode is TOPIC_FOCUS, which topic

  // User tracking for individual progress in shared circles
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  attempts ExamQuestionAttempt[]

  createdAt DateTime @default(now())

  @@index([examPrepId])
  @@index([userId])
  @@index([examPrepId, userId])
  @@index([examPrepId, createdAt])
}

model ExamQuestionAttempt {
  id            String          @id @default(cuid())
  quizSessionId String
  quizSession   ExamQuizSession @relation(fields: [quizSessionId], references: [id], onDelete: Cascade)
  questionId    String
  question      ExamQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  userAnswer       String
  isCorrect        Boolean
  timeTakenSeconds Int?

  createdAt DateTime @default(now())

  @@index([quizSessionId])
  @@index([questionId])
  @@index([questionId, isCorrect])
}

// ==========================================
//  USER MEMORY & PERSONALIZATION MODULE
// ==========================================

model UserInteractionMemory {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  interactionType InteractionType
  entityType      String // "resource", "course", "note", "goal", "chat"
  entityId        String? // ID of the entity interacted with

  // Interaction details
  metadata   Json? // Additional context (e.g., search query, time spent, feedback score)
  importance Float @default(0.5) // 0.0 to 1.0 - how important this interaction is for personalization

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, interactionType])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
}

// ==========================================
//  USER FACTS (AI MEMORY)
// ==========================================

model UserFact {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  category String // "preference", "personal", "academic", "goal", "struggle", "strength", "other"
  content  String // The fact itself, e.g. "Prefers visual learning", "Exam is in March 2026"
  source   String @default("conversation") // "conversation", "onboarding", "manual"

  confidence Float   @default(0.8) // 0.0 to 1.0 - how confident we are this fact is accurate
  isActive   Boolean @default(true) // Soft delete / superseded facts

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, category])
  @@index([userId, isActive])
}

// ==========================================
//  ANALYTICS MODULE
// ==========================================

model StudySession {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Session details
  startTime DateTime
  endTime   DateTime?
  duration  Float // Duration in minutes (calculated when session ends)

  // Context (what was studied)
  courseId String?
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  topicId  String?
  topic    Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  // Circle context
  circleId String?
  circle   Circle? @relation(fields: [circleId], references: [id], onDelete: SetNull)

  // Metadata
  metadata Json? // Additional context (device, location, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, startTime])
  @@index([courseId])
  @@index([topicId])
  @@index([startTime])
  @@index([circleId])
}

model UserStreak {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Streak tracking
  currentStreak Int       @default(0) // Current consecutive days
  longestStreak Int       @default(0) // Longest streak ever achieved
  lastStudyDate DateTime? // Last date user studied (for streak calculation)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum AchievementType {
  STUDY_TIME_MILESTONE // e.g., "Studied 100 hours"
  STREAK_MILESTONE // e.g., "7 day streak"
  COURSE_COMPLETION // e.g., "Completed first course"
  GOAL_ACHIEVEMENT // e.g., "Completed 10 goals"
  TOPIC_COMPLETION // e.g., "Completed 50 topics"
  AI_USAGE // e.g., "Sent 100 AI messages"
}

model Achievement {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievementType AchievementType
  title           String // e.g., "7 Day Streak"
  description     String? // e.g., "You've studied for 7 consecutive days!"
  icon            String? // Icon identifier or emoji
  metadata        Json? // Additional data (e.g., milestone value)

  unlockedAt DateTime @default(now())

  @@index([userId])
  @@index([userId, achievementType])
  @@index([unlockedAt])
}

// ==========================================
//  FEEDBACK MODULE
// ==========================================

enum FeedbackType {
  BUG_REPORT
  FEATURE_REQUEST
  GENERAL_FEEDBACK
  UI_UX_FEEDBACK
  PERFORMANCE_ISSUE
  OTHER
}

enum FeedbackStatus {
  PENDING
  REVIEWED
  RESOLVED
  ARCHIVED
}

enum CareerApplicationStatus {
  NEW
  REVIEWED
  ARCHIVED
}

model Feedback {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Feedback content
  type        FeedbackType
  title       String
  description String
  status      FeedbackStatus @default(PENDING)

  // Optional context
  pageUrl   String? // URL where feedback was submitted from
  userAgent String? // Browser/device info
  metadata  Json? // Additional context (e.g., screenshots, logs)

  // Admin response
  adminNotes String?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model CareerApplication {
  id String @id @default(cuid())

  jobId    String
  jobTitle String

  firstName    String
  lastName     String
  email        String
  linkedinUrl  String
  portfolioUrl String?

  coverLetter String @db.Text

  status     CareerApplicationStatus @default(NEW)
  adminNotes String?

  userAgent String?
  sourceIp  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
  @@index([status])
  @@index([createdAt])
  @@index([email])
}

// ==========================================
//  MARKETING CMS (blog + careers), managed in admin
// ==========================================

model BlogPost {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  description String   @db.Text
  content     String   @db.Text
  authorName  String
  authorRole  String?
  publishedAt DateTime
  tags        String[]
  category    String
  coverImage  String?
  readTime    Int?
  featured    Boolean  @default(false)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published])
  @@index([publishedAt])
}

model JobPosting {
  id                     String   @id @default(uuid())
  slug                   String   @unique
  title                  String
  location               String
  type                   String
  stage                  String
  description            String   @db.Text
  responsibilities       String[]
  requirementsMustHave   String[]
  requirementsNiceToHave String[]
  successMetrics         String[]
  whyRoleMatters         String[]
  compensation           String[]
  published              Boolean  @default(true)
  sortOrder              Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([published])
  @@index([sortOrder])
}

// ==========================================
//  REFERRAL MODULE
// ==========================================

model ReferralReward {
  id String @id @default(uuid())

  referrerId String // User who referred someone
  referrer   User   @relation(fields: [referrerId], references: [id], onDelete: Cascade)

  referredUserId String // User who was referred
  referredUser   User   @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)

  rewardType String // "signup" (1000 tokens) or "subscription" (500 tokens)
  tokens     Int       @default(0) // Amount of tokens awarded
  isClaimed  Boolean   @default(false) // Whether the reward has been claimed
  claimedAt  DateTime? // When the reward was claimed
  claimDate  DateTime? // The date when claimed (for daily limit tracking)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([referrerId, referredUserId, rewardType]) // One reward per referrer-referred pair per type
  @@index([referrerId])
  @@index([referredUserId])
  @@index([isClaimed])
}

model ReferralRewardClaim {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rewardId           String // Reference to ReferralReward (not a relation to avoid circular dependency)
  tokensClaimed      Int // Amount claimed
  claimDate          DateTime // Date when claimed (for daily limit tracking)
  dailyLimitIncrease Int      @default(0) // How much daily limit was increased

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([rewardId])
  @@index([claimDate])
}

// ==========================================
//  RESOURCE BANK MODULE
// ==========================================

model ResourceBankItem {
  id         String @id @default(cuid())
  uploaderId String
  uploader   User   @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  title          String
  description    String?
  type           ResourceBankType @default(OTHER)
  universityName String
  courseName     String?
  courseCode     String?

  status          ResourceBankStatus @default(PENDING_REVIEW)
  moderationNotes String?

  downloadCount Int @default(0)
  viewCount     Int @default(0)
  reportCount   Int @default(0)

  // Relations
  files      ResourceBankFile[]
  embeddings Embedding[]
  reports    ResourceBankReport[]
  rewards    ResourceUploadReward[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([universityName])
  @@index([courseCode])
  @@index([type])
  @@index([status])
  @@index([uploaderId])
  @@index([universityName, courseCode])
  @@index([universityName, type])
}

model ResourceBankFile {
  id                 String           @id @default(cuid())
  resourceBankItemId String
  resourceBankItem   ResourceBankItem @relation(fields: [resourceBankItemId], references: [id], onDelete: Cascade)

  filename      String
  url           String
  size          Int?
  mimeType      String?
  extractedText String? // For RAG indexing of PDFs/docs

  createdAt DateTime @default(now())

  @@index([resourceBankItemId])
}

model ResourceBankReport {
  id                 String           @id @default(cuid())
  resourceBankItemId String
  resourceBankItem   ResourceBankItem @relation(fields: [resourceBankItemId], references: [id], onDelete: Cascade)

  reporterId String
  reporter   User   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  reason      String
  description String?
  status      ReportStatus @default(REPORT_PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([resourceBankItemId, reporterId])
  @@index([resourceBankItemId])
  @@index([reporterId])
  @@index([status])
}

model ResourceUploadReward {
  id String @id @default(uuid())

  uploaderId String
  uploader   User   @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  resourceBankItemId String
  resourceBankItem   ResourceBankItem @relation(fields: [resourceBankItemId], references: [id], onDelete: Cascade)

  tokens    Int       @default(1500)
  isClaimed Boolean   @default(false)
  claimedAt DateTime?
  claimDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([uploaderId, resourceBankItemId])
  @@index([uploaderId])
  @@index([resourceBankItemId])
  @@index([isClaimed])
}

model ResourceUploadRewardClaim {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  rewardId           String
  tokensClaimed      Int
  claimDate          DateTime
  dailyLimitIncrease Int      @default(0)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([rewardId])
  @@index([claimDate])
}

// ==========================================
//  AUDIT LOG MODULE
// ==========================================

model AuditLog {
  id String @id @default(uuid())

  adminUserId String // ID of admin user who performed the action
  adminUser   User?  @relation("AdminAuditLogs", fields: [adminUserId], references: [id], onDelete: SetNull)

  actionType   String // e.g., "create_user", "delete_course", "adjust_credits"
  resourceType String // e.g., "user", "course", "subscription"
  resourceId   String? // ID of the resource affected (optional)

  details Json? // Additional details about the action (JSON object)

  timestamp DateTime @default(now())

  @@index([adminUserId])
  @@index([actionType])
  @@index([resourceType])
  @@index([timestamp])
  @@index([resourceType, resourceId])
}

/// Super-admin ledger: income and expenses with original currency and GBP equivalent.
model LedgerLine {
  id          String         @id @default(cuid())
  kind        LedgerLineKind
  title       String
  description String?

  /// Amount in `currency` (original).
  amount    Decimal @db.Decimal(18, 4)
  currency  String  @db.VarChar(3)

  /// Sterling equivalent for reporting (auto or manual).
  amountGbp Decimal @db.Decimal(18, 4)

  /// Multiply `amount` by this to get `amountGbp` (1.0 when currency is GBP).
  gbpPerUnit Decimal? @db.Decimal(18, 10)

  /// FX quote date (YYYY-MM-DD) when `fxSource` is frankfurter.
  fxAsOfDate String? @db.VarChar(10)
  fxSource   String  @db.VarChar(32) // frankfurter | identity | manual

  occurredAt DateTime

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind, occurredAt])
  @@index([occurredAt])
}

// ==========================================
//  CIRCLE MODULE (Study Groups)
// ==========================================

model Circle {
  id          String  @id @default(cuid())
  name        String
  description String?
  avatarUrl   String?
  createdById String
  maxMembers  Int     @default(5)
  maxGroups   Int     @default(5)

  // Credits & Wallet
  credits      Int  @default(0)
  creditsLimit Int?

  // Relations
  members    CircleMember[]
  invites    CircleInvite[]
  notes      Note[]
  goals      Goal[]
  courses    Course[]
  chatGroups CircleChatGroup[]
  resources  Resource[]
  examPreps  ExamPrep[]
  studySessions StudySession[]
  memberStats CircleMemberStat[]
  groupSessions CircleSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdById])
}

model CircleMember {
  id       String     @id @default(cuid())
  circleId String
  circle   Circle     @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     CircleRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  @@unique([circleId, userId])
  @@index([userId])
  @@index([circleId])
}

/// Up to 5 named chat groups within a circle
model CircleChatGroup {
  id       String @id @default(cuid())
  circleId String
  circle   Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  name     String // e.g., "General", "Exam Prep", "Biology"

  // Reuses existing ChatSession model for messages
  chatSessionId String?      @unique
  chatSession   ChatSession? @relation(fields: [chatSessionId], references: [id], onDelete: SetNull)

  groupSessions CircleSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([circleId])
}

model CircleInvite {
  id           String             @id @default(cuid())
  circleId     String
  circle       Circle             @relation(fields: [circleId], references: [id], onDelete: Cascade)
  inviterId    String // User who sent the invite
  inviteeEmail String // Email of the person invited
  inviteeId    String? // User ID if they're already on the platform
  status       CircleInviteStatus @default(PENDING)
  expiresAt    DateTime
  createdAt    DateTime           @default(now())

  @@unique([circleId, inviteeEmail])
  @@index([inviteeEmail])
  @@index([inviteeId])
  @@index([circleId])
}

model CircleMemberStat {
  id       String @id @default(cuid())
  circleId String
  circle   Circle @relation(fields: [circleId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  contributionPoints Int @default(0)
  coursesCompleted   Int @default(0)
  notesAdded         Int @default(0)
  resourcesShared    Int @default(0)
  quizAverage        Float @default(0.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([circleId, userId])
  @@index([circleId])
  @@index([userId])
}

model CircleSession {
  id          String   @id @default(cuid())
  circleId    String
  circle      Circle   @relation(fields: [circleId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  
  scheduledAt DateTime
  duration    Int      @default(60) // minutes
  status      CircleSessionStatus @default(SCHEDULED)
  
  // Optional linkage to a specific chat group where the session takes place
  chatGroupId String?
  chatGroup   CircleChatGroup? @relation(fields: [chatGroupId], references: [id], onDelete: SetNull)

  // Optional linkage to a topic or goal
  topicId     String?
  topic       Topic?   @relation(fields: [topicId], references: [id], onDelete: SetNull)
  goalId      String?
  goal        Goal?    @relation(fields: [goalId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([circleId])
  @@index([scheduledAt])
  @@index([status])
  @@index([chatGroupId])
  @@index([topicId])
  @@index([goalId])
  @@index([createdById])
}

// ==========================================
//  AGENTIC AI MODULE
// ==========================================

/// Conversation summaries for long-term AI memory
model ConversationSummary {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  summary       String // LLM-generated summary of the conversation
  keyTopics     String[] @default([]) // Main topics discussed
  actionsTaken  String[] @default([]) // Actions the AI took (create_course, etc.)
  emotionalTone String? // User's emotional state (frustrated, motivated, etc.)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
  @@index([sessionId])
}

/// AI-initiated background tasks (proactive agent nudges)
model AIAgentTask {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskType    String // "goal_nudge", "review_reminder", "study_gap", "plan_checkpoint"
  status      String    @default("pending") // "pending", "sent", "dismissed", "acted_on"
  priority    Int       @default(5) // 1-10 priority
  title       String
  message     String // The nudge message
  actionData  Json? // Suggested action payload
  scheduledAt DateTime // When to send this nudge
  sentAt      DateTime?
  dismissedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([scheduledAt, status])
}

/// Learning insights derived from user behavior analysis
model LearningInsight {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  insightType String // "study_pattern", "strength", "weakness", "optimal_time", "strategy_effectiveness"
  content     String
  confidence  Float  @default(0.7)
  dataPoints  Int    @default(1) // How many data points this insight is based on
  metadata    Json?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, insightType])
  @@index([userId, isActive])
}

// ==========================================
//  KNOWLEDGE BASE (User Uploads)
// ==========================================

model UserUpload {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  url           String // CDN URL of the uploaded file
  filename      String
  mimeType      String?
  size          Int? // File size in bytes
  extractedText String? // Text extracted via OCR / Gemini Vision
  embeddingId   String? // Reference to Embedding record (if indexed)
  chatMessageId String? // Which chat message triggered this upload

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, createdAt])
}
